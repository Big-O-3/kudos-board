# ──────────────────────────────────────────────────────────────────────────
# Backend environment template (Brandon's Cards app)
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# If you use Postgres.app on macOS, USER is your macOS username and there is no
# password, e.g.  postgresql://yourname@localhost:5432/kudos_cards_brandon?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/kudos_cards_brandon?schema=public"

# Port the Express server listens on.
PORT=5000
